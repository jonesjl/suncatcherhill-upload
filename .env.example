# Local development uses .env.local, which is ignored by git.
# Production should use Amplify environment variables/secrets.

AWS_REGION=us-east-1
S3_BUCKET_NAME=suncatcherhill.com
CLOUDFRONT_BASE_URL=https://suncatcherhill.com

# Auth.js / NextAuth
AUTH_SECRET=
AUTH_TRUST_HOST=true
AUTH_URL=http://localhost:3000

# AWS Cognito
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
COGNITO_ISSUER=

# Comma-separated allowlist of emails allowed to upload
ALLOWED_UPLOAD_EMAILS=

# Only needed in deployed environments if not using an IAM role
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
